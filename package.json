{
  "name": "contact-intelligence",
  "version": "0.1.0",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "start": "bun run src/index.ts",
    "seed": "bun run src/db/seed.ts",
    "sync:events": "bun run scripts/sync-events.ts",
    "sync:surveys": "bun run scripts/sync-surveys.ts",
    "sync:materialize": "bun run scripts/materialize.ts",
    "sync:all": "bun run scripts/sync-events.ts && bun run scripts/sync-surveys.ts && bun run scripts/materialize.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "typed-htmx": "^0.3.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@duckdb/node-api": "^1.4.4-r.1",
    "hono": "^4.12.2",
    "zod": "^4.3.6"
  }
}
